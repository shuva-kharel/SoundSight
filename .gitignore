# ===========================================================================
#  SoundSight  --  .gitignore
#  Goal: commit CODE + small assets you can't regenerate (trained banknote
#  model, pre-recorded Nepali phrases). Ignore secrets, virtualenvs, caches,
#  training data, and BIG models that download/export automatically.
# ===========================================================================

# --- Secrets & local config -- NEVER commit -------------------------------
.env
.env.*
!.env.example

# --- Local HTTPS cert (regenerated automatically on first run) -------------
cert.pem
key.pem

# --- Python ----------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- Big / auto-downloaded models (NOT needed in the repo) -----------------
# CLIP weights for YOLO-World open-vocab -- 337 MB, auto-downloads on first use.
weights/
# Stock Ultralytics YOLO weights + their NCNN exports -- auto-download/export.
yolo*.pt
yolo*_ncnn_model/
# (KEPT in the repo on purpose: models/banknote.pt + models/banknote_ncnn_model/
#  -- your TRAINED model, small and not re-downloadable.)

# --- Training data & outputs (large, regenerable) --------------------------
dataset/
runs/
banknote_runs/

# --- Local-only user data (NEVER commit faces!) ----------------------------
faces_db/
models_vosk/
vosk-model*/

# --- Editor / tooling / OS junk --------------------------------------------
.claude/
.vscode/
.idea/
*.swp
Thumbs.db
.DS_Store
